%YAML 1.2
---
# https://learn.microsoft.com/en-us/dotnet/csharp/specification/
# https://github.com/dotnet/csharpstandard/blob/standard-v7/standard/
# https://www.sublimetext.com/docs/syntax.html
name: C#
scope: source.cs
version: 2

file_extensions:
  - cs
  - csx

first_line_match: |-
  (?xi:
    ^ \#! .* {{shebang_language}}                       # shebang
  | ^ \s* // .*? -\*- .*? \b(c\#|cs|csharp)\b .*? -\*-  # editorconfig
  )

contexts:
  prototype:
    - include: comments
    - include: preprocessor_directives

  main:
    - meta_include_prototype: false
    - match: ''
      push: [statements, shebang]

###[ COMMENTS ]################################################################

  comments:
    - match: ^\s*(///)
      captures:
        1: punctuation.definition.comment.documentation.cs
      push: inside_doc_comment
    - match: //
      scope: punctuation.definition.comment.cs
      push: inside_line_comment
    - match: /\*\*+/
      scope: comment.block.empty.cs punctuation.definition.comment.cs
    - match: /\*+
      scope: punctuation.definition.comment.begin.cs
      push: inside_block_comment
    - include: merge-conflict-markers

  inside_block_comment:
    - meta_scope: comment.block.cs
    - match: \*+/
      scope: punctuation.definition.comment.end.cs
      pop: 1
    - match: ^\s*(\*)(?!\**/)
      captures:
        1: punctuation.definition.comment.cs
    - include: comment_content

  inside_doc_comment:
    - meta_include_prototype: false
    - meta_scope: comment.line.documentation.cs
    - match: ^\s*(///)
      captures:
        1: punctuation.definition.comment.documentation.cs
    - match: ^
      pop: 1
    - match: (<)({{name}})
      captures:
        1: punctuation.definition.tag.begin.cs
        2: entity.name.tag.begin.cs
      push: inside_doc_comment_tag
    - match: (</)({{name}})(>)
      scope: meta.tag.xml
      captures:
        1: punctuation.definition.tag.begin.cs
        2: entity.name.tag.end.cs
        3: punctuation.definition.tag.end.cs
    - include: comment_content

  inside_doc_comment_tag:
    - meta_include_prototype: false
    - meta_scope: meta.tag.xml
    - match: /?>
      scope: punctuation.definition.tag.end.cs
      pop: 1
    - match: ^\s*(///)
      captures:
        1: punctuation.definition.comment.documentation.cs
    - match: ^
      pop: 2
    - match: ({{name}})\s*(=)
      captures:
        1: entity.other.attribute-name.cs
        2: punctuation.separator.key-value.cs
    - match: \"
      scope: punctuation.definition.string.begin.cs
      push: inside_string

  inside_line_comment:
    - meta_scope: comment.line.double-slash.cs
    - match: $\n?
      pop: 1
    - include: comment_content

  comment_content:
    - include: merge-conflict-markers
    - match: \b(?i:todo|hack|xxx)\b
      scope: comment.line.todo.cs
    - match: /!\\
      scope: comment.line.todo.cs
    - match: \b[a-z+]+://\S*(?:[:/#?&=]|\b)
      scope: markup.underline.link.cs

  shebang:
    - meta_include_prototype: false
    - match: ^\s*(\#!)
      captures:
        1: punctuation.definition.comment.cs
      set: inside_shebang
    - match: ^|(?=\S)  # Note: Ensure to highlight shebang if C# is embedded.
      pop: 1

  inside_shebang:
    - meta_include_prototype: false
    - meta_scope: comment.line.shebang.cs
    - match: '{{shebang_language}}'
      scope: constant.language.shebang.cs
    - match: $\n?
      pop: 1

###[ MERGE CONFLICT MARKERS ]##################################################

  merge-conflict-markers:
    # see also: Diff.sublime-syntax#conflict-markers
    - match: ^(<{7})(?:\s+(\S.*?))?$\n?
      scope: meta.block.conflict.begin.diff
      captures:
        1: punctuation.section.block.begin.diff
        2: entity.name.section.diff
    - match: ^(>{7})(?:\s+(\S.*?))?$\n?
      scope: meta.block.conflict.end.diff
      captures:
        1: punctuation.section.block.end.diff
        2: entity.name.section.diff
    - match: ^(\|{7}|={7})(?:\s+(\S.*?))?$\n?
      scope: meta.block.conflict.separator.diff
      captures:
        1: punctuation.section.block.diff
        2: entity.name.section.diff

###[ ANNOTATIONS ]#############################################################

  attributes:
    - match: \[
      scope: punctuation.definition.annotation.begin.cs
      push:
        - inside_attribute
        - attribute_modifier

  attribute_modifier:
    - match: (assembly|module|field|event|method|param|property|return|type)\s*(:)
      captures:
        1: storage.modifier.target.cs
        2: punctuation.separator.key-value.cs
      pop: 1
    - include: else_pop

  inside_attribute:
    - meta_scope: meta.annotation.cs
    - match: \]
      scope: punctuation.definition.annotation.end.cs
      pop: 1
    - match: \(
      scope: meta.group.cs punctuation.section.group.begin.cs
      push: inside_argument_list
    - match: ','
      scope: punctuation.separator.annotation.cs
    - include: namespace_variables
    - match: (GeneratedRegex)\s*(\()
      captures:
        1: variable.annotation.cs
        2: meta.group.cs punctuation.section.group.begin.cs
      push:
        - inside_argument_list
        - immediately_pop
        - regex_string
    - match: (?={{name}})
      push: attribute_name

  attribute_name:
    - meta_include_prototype: false
    - meta_content_scope: variable.annotation.cs
    - include: type_common_except_bare_custom_type
    - include: noeol_pop

  inside_argument_list:
    - meta_content_scope: meta.group.cs
    - match: \)
      scope: meta.group.cs punctuation.section.group.end.cs
      pop: 1
    - include: arguments

###[ PREPROCESSOR DIRECTIVES ]#################################################

  preprocessor_directives:
    - match: ^(?=\s*#)
      push: preprocessor_directive

  preprocessor_directive:
    - meta_include_prototype: false
    - meta_scope: meta.preprocessor.cs
    # Note: Repeated `\s*(#)` is required as some of them are to be scoped
    #       fold markers to support syntax based folding of blocks.
    - match: \s*(#:)(\w+)\b(?:\s*(\S.*?))?{{wspace_eol}}
      captures:
        1: punctuation.definition.preprocessor.cs
        2: variable.language.cs
        3: meta.string.cs string.unquoted.cs
      pop: 1
    - match: \s*(#)\s*(region)\b(?:\s*(\S.*?))?({{wspace_eol}})
      captures:
        1: punctuation.definition.preprocessor.cs
        2: keyword.control.directive.region.cs
        3: entity.name.section.cs
        4: meta.fold.block.begin.cs
      pop: 1
    - match: \s*(#)\s*(endregion)\b(?:\s*(\S.*?))?{{wspace_eol}}
      captures:
        1: meta.fold.block.end.cs punctuation.definition.preprocessor.cs
        2: keyword.control.directive.endregion.cs
        3: variable.other.section.cs
      pop: 1
    - match: \s*(#)\s*(?:(error)|(warning))\b(?:\s*(\S.*?))?{{wspace_eol}}
      captures:
        1: punctuation.definition.preprocessor.cs
        2: keyword.control.directive.error.cs
        3: keyword.control.directive.warning.cs
        4: meta.string.cs string.unquoted.cs
      pop: 1
    - match: \s*(#)\s*(line)\b
      captures:
        1: punctuation.definition.preprocessor.cs
        2: keyword.control.directive.line.cs
      set: preprocessor_line
    - match: \s*(#)\s*(if)\b
      captures:
        1: punctuation.definition.preprocessor.cs
        2: keyword.control.directive.conditional.if.cs
      set: preprocessor_if_condition
    - match: \s*(#)\s*(elif)\b
      captures:
        1: meta.fold.block.end.cs punctuation.definition.preprocessor.cs
        2: keyword.control.directive.conditional.elseif.cs
      set: preprocessor_if_condition
    - match: \s*(#)\s*(else)\b
      captures:
        1: meta.fold.block.end.cs punctuation.definition.preprocessor.cs
        2: keyword.control.directive.conditional.else.cs
      set: expect_preprocessor_fold_begin
    - match: \s*(#)\s*(endif)\b
      captures:
        1: meta.fold.block.end.cs punctuation.definition.preprocessor.cs
        2: keyword.control.directive.conditional.end.cs
      set: expect_preprocessor_end
    - match: \s*(#)\s*(?:(define)|(undef))\b(?:\s*({{name}}))?
      captures:
        1: punctuation.definition.preprocessor.cs
        2: keyword.control.directive.define.cs
        3: keyword.control.directive.undefine.cs
        4: entity.name.constant.preprocessor.cs
      set: expect_preprocessor_end
    - match: \s*(#)\s*(nullable)(?:\s+(enable|disable|restore)(?:\s+(annotations|warnings))?)?\b
      captures:
        1: punctuation.definition.preprocessor.cs
        2: keyword.control.directive.nullable.cs
        3: keyword.control.directive.other.cs
        4: constant.language.messages.cs
      set: expect_preprocessor_end
    - match: \s*(#)\s*(pragma)\b
      captures:
        1: punctuation.definition.preprocessor.cs
        2: keyword.control.directive.pragma.cs
      set: preprocessor_pragma_name
    - match: \s*(#)\s*({{name}})
      captures:
        1: punctuation.definition.preprocessor.cs
    - match: $\n?|(?=\s*/[/*])
      pop: 1

  preprocessor_if_condition:
    - meta_content_scope: meta.preprocessor.cs
    - match: \(
      scope: punctuation.section.group.begin.cs
      push: inside_preprocessor_if_condition_group
    - match: (?:&&|\|\||!)
      scope: keyword.operator.logical.cs
    - include: constants
    - match: '{{name}}'
      scope: constant.other.preprocessor.cs
    - include: expect_preprocessor_fold_begin

  inside_preprocessor_if_condition_group:
    - meta_scope: meta.group.cs
    - match: \)
      scope: punctuation.section.group.end.cs
      pop: 1
    - include: preprocessor_if_condition

  preprocessor_line:
    - meta_content_scope: meta.preprocessor.cs
    - match: \"
      scope: punctuation.definition.string.begin.cs
      push: inside_string
    - match: (?:default|hidden)\b
      scope: constant.language.preprocessor.cs
    - match: \d+
      scope: meta.number.integer.decimal.cs constant.numeric.value.cs
    - include: expect_preprocessor_end

  preprocessor_pragma_name:
    - meta_content_scope: meta.preprocessor.cs
    - match: checksum\b
      scope: meta.preprocessor.cs entity.name.pragma.checksum.cs
      set: preprocessor_pragma_checksum_args
    - match: warning\b
      scope: meta.preprocessor.cs entity.name.pragma.warning.cs
      set: preprocessor_pragma_warning_args
    - match: '{{name}}'
      scope: meta.preprocessor.cs entity.name.pragma.other.cs
      set: preprocessor_pragma_other_args
    - include: expect_preprocessor_end

  preprocessor_pragma_checksum_args:
    - meta_content_scope: meta.preprocessor.cs
    - match: \"\{
      scope: punctuation.definition.string.begin.cs
      push: inside_preprocessor_pragma_checksum_hash
    - match: \"
      scope: punctuation.definition.string.begin.cs
      push: inside_string
    - include: expect_preprocessor_end

  inside_preprocessor_pragma_checksum_hash:
    - meta_include_prototype: false
    - meta_scope: meta.string.hash.cs string.quoted.double.cs
    - meta_content_scope: meta.number.integer.hexadecimal.cs constant.numeric.value.cs
    - match: \}\"
      scope: punctuation.definition.string.end.cs
      pop: 1
    - match: $\n?
      scope: invalid.illegal.unclosed-string.cs
      pop: 1
    - match: '[^-\h]+'
      scope: invalid.illegal.cs

  preprocessor_pragma_other_args:
    - meta_content_scope: meta.preprocessor.cs
    - match: \"
      scope: punctuation.definition.string.begin.cs
      push: inside_string
    - match: \d+
      scope: meta.number.integer.decimal.cs constant.numeric.value.cs
    - match: '[\p{L}_-]+'
      scope: meta.string.cs string.unquoted.cs
    - include: expect_preprocessor_end

  preprocessor_pragma_warning_args:
    - meta_content_scope: meta.preprocessor.cs
    - match: (disable|restore)(?:\s+([\w-]+))?
      scope: meta.preprocessor.cs
      captures:
        1: keyword.control.directive.other.cs
        2: meta.string.cs string.unquoted.cs
      set: expect_preprocessor_end
    - include: expect_preprocessor_end

  expect_preprocessor_end:
    - meta_include_prototype: false
    - meta_content_scope: meta.preprocessor.cs
    - match: $\n?|(?=\s*/[/*])
      scope: meta.preprocessor.cs
      pop: 1
    - match: \S+
      scope: invalid.illegal.cs

  expect_preprocessor_fold_begin:
    - meta_include_prototype: false
    - meta_content_scope: meta.preprocessor.cs
    - match: '{{wspace_eol}}'
      scope: meta.preprocessor.cs meta.fold.block.begin.cs
      pop: 1
    - match: \s*(?=/[/*])
      scope: meta.fold.block.begin.cs
      pop: 1
    - match: \S+
      scope: invalid.illegal.cs

###[ GLOBAL STATEMENTS ]#######################################################

  statements:
    - match: \{
      scope: punctuation.section.block.begin.cs
      push: inside_global_block
    - include: stray_close_bracket
    - include: attributes
    - include: modifiers
    - include: using_declaration
    - include: class_declaration
    - include: enum_declaration
    - include: interface_declaration
    - include: record_declaration
    - include: struct_declaration
    - include: delegate_declaration
    - include: namespace_declaration
    # allows coloration of code outside a class
    - include: code_block_in

  inside_global_block:
    - meta_scope: meta.block.cs
    - match: \}
      scope: punctuation.section.block.end.cs
      pop: 1
    - include: statements

  stray_close_bracket:
    - match: '[]})]'
      scope: invalid.illegal.stray.brace.cs

###[ USING DECLARATIONS ]######################################################

  using_declaration:
    - match: (?:(global)\s+)?(using)\b
      captures:
        1: storage.modifier.cs
        2: keyword.declaration.using.cs
      push:
        - using_meta
        - using_type

  using_meta:
    - meta_include_prototype: false
    - meta_scope: meta.using.cs
    - include: immediately_pop

  using_type:
    - match: static\b
      scope: storage.modifier.static.cs
      set: using_namespace
    - match: ({{name}})\s*(=)\s*(?=\()
      captures:
        1: entity.name.type.cs
        2: keyword.operator.assignment.cs
      set: type_tuple
    - match: (?=var\b|{{namespaced_name}}{{type_suffix}}?\s+{{name}})
      set:
        - variable_declaration_list
        - var_declaration
    - match: (?=\S)
      set: using_namespace

  using_namespace:
    - include: namespace_variables
    - include: type_argument_lists
    - match: (?=;|{{reserved}}\b)
      pop: 1
    - match: '{{name}}'
      scope: meta.path.cs
    - match: '='
      scope: keyword.operator.assignment.cs
      push: maybe_pointer
    - match: \.
      scope: meta.path.cs punctuation.accessor.dot.cs
    - match: '[^\s;]+'
      scope: invalid.illegal.expected-namespace.cs

###[ NAMESPACE DECLARATIONS ]##################################################

  namespace_declaration:
    # package declaration
    - match: namespace\b
      scope: meta.namespace.cs keyword.declaration.namespace.cs
      push:
        - namespace_declaration_block
        - namespace_declaration_name

  namespace_declaration_name:
    - match: ({{unreserved_name}})\s*(\.)
      captures:
        1: variable.namespace.cs
        2: punctuation.accessor.dot.cs
      set: qualified_namespace_declaration_name
    - include: unqualified_namespace_declaration_name

  qualified_namespace_declaration_name:
    - meta_scope: meta.path.cs
    - match: ({{unreserved_name}})\s*(\.)
      captures:
        1: variable.namespace.cs
        2: punctuation.accessor.dot.cs
    - include: unqualified_namespace_declaration_name

  unqualified_namespace_declaration_name:
    - match: '{{unreserved_name}}'
      scope: entity.name.namespace.cs
      pop: 1
    - include: else_pop

  namespace_declaration_block:
    - meta_content_scope: meta.namespace.cs
    - match: \{
      scope: punctuation.section.block.begin.cs
      set: inside_namespace_declaration_block
    - include: else_pop

  inside_namespace_declaration_block:
    - meta_scope: meta.namespace.body.cs meta.block.cs
    - match: \}
      scope: punctuation.section.block.end.cs
      pop: 1
    - include: statements

###[ CLASS DECLARATIONS ]######################################################

  class_declaration:
    - match: class\b
      scope: meta.class.cs keyword.declaration.class.cs
      push:
        - class_block
        - class_base
        - class_parameter_list
        - type_parameter_list
        - class_declaration_name

  class_declaration_name:
    - match: '{{unreserved_name}}'
      scope: entity.name.class.cs
      pop: 1
    - include: else_pop

  class_parameter_list:
    - match: \(
      scope: punctuation.section.parameters.begin.cs
      set: inside_class_parameter_list
    - include: else_pop

  inside_class_parameter_list:
    - clear_scopes: 1
    - meta_scope: meta.class.parameters.cs
    - include: inside_method_parameter_list

  class_base:
    - match: ':'
      scope: punctuation.separator.type.cs
      set: inside_class_base
    - match: (?=where\b)
      set: type_constraints
    - include: else_pop

  inside_class_base:
    - clear_scopes: 1
    - meta_scope: meta.class.base.cs
    - include: inherited_classes

  class_block:
    - meta_content_scope: meta.class.cs
    - match: \{
      scope: punctuation.section.block.begin.cs
      set: inside_class_block
    - include: else_pop

  inside_class_block:
    - meta_scope: meta.class.body.cs meta.block.cs
    - match: \}
      scope: punctuation.section.block.end.cs
      pop: 1
    - include: stray_close_bracket
    - include: terminators
    - include: attributes
    - include: modifiers
    - include: class_declaration
    - include: enum_declaration
    - include: interface_declaration
    - include: record_declaration
    - include: struct_declaration
    - include: delegate_declaration
    - include: event_declaration
    - include: extension_declaration
    - include: constructor_declaration
    - include: conversion_declaration
    - include: member_declaration

###[ ENUM DECLARATIONS ]#######################################################

  enum_declaration:
    - match: enum\b
      scope: meta.enum.cs keyword.declaration.enum.cs
      push:
        - enum_block
        - enum_base
        - enum_declaration_name

  enum_declaration_name:
    - match: '{{unreserved_name}}'
      scope: entity.name.enum.cs
      pop: 1
    - include: else_pop

  enum_base:
    - match: ':'
      scope: punctuation.separator.type.cs
      set: inside_enum_base
    - include: else_pop

  inside_enum_base:
    - clear_scopes: 1
    - meta_scope: meta.enum.base.cs
    - match: (?:byte|sbyte|short|ushort|int|uint|nint|nuint|long|ulong)\b
      scope: storage.type.cs
      pop: 1
    - match: '{{base_type}}'
      scope: invalid.illegal.type.cs
      pop: 1
    - match: '{{unreserved_name}}'
      scope: support.type.cs
      pop: 1
    - include: else_pop

  enum_block:
    - meta_content_scope: meta.enum.cs
    - match: \{
      scope: punctuation.section.block.begin.cs
      set: inside_enum_block
    - include: else_pop

  inside_enum_block:
    - meta_scope: meta.enum.body.cs meta.block.cs
    - match: \}
      scope: punctuation.section.block.end.cs
      pop: 1
    - include: attributes
    - match: '{{unreserved_name}}'
      scope: entity.name.constant.cs
    - match: ','
      scope: punctuation.separator.enum.cs
    - include: assignment_expressions

###[ INTERFACE DECLARATIONS ]##################################################

  interface_declaration:
    - match: interface\b
      scope: meta.interface.cs keyword.declaration.interface.cs
      push:
        - interface_block
        - interface_base
        - type_parameter_list
        - interface_declaration_name

  interface_declaration_name:
    - match: '{{unreserved_name}}'
      scope: entity.name.interface.cs
      pop: 1
    - include: else_pop

  interface_base:
    - match: ':'
      scope: punctuation.separator.type.cs
      set: inside_interface_base
    - match: (?=where\b)
      set: type_constraints
    - include: else_pop

  inside_interface_base:
    - clear_scopes: 1
    - meta_scope: meta.interface.base.cs
    - include: inherited_classes

  interface_block:
    - meta_content_scope: meta.interface.cs
    - match: \{
      scope: punctuation.section.block.begin.cs
      set: inside_interface_block
    - include: else_pop

  inside_interface_block:
    - meta_scope: meta.interface.body.cs meta.block.cs
    - include: inside_class_block

###[ RECORD DECLARATIONS ]#####################################################

  record_declaration:
    - match: record\b
      scope: meta.record.cs keyword.declaration.record.cs
      push:
        - record_block
        - record_base
        - record_parameter_list
        - type_parameter_list
        - record_name

  record_name:
    - match: struct\b
      scope: keyword.declaration.struct.cs
      set: struct_declaration_name
    - match: class\b
      scope: keyword.declaration.class.cs
      set: class_declaration_name
    - include: class_declaration_name

  record_parameter_list:
    - match: \(
      scope: punctuation.section.parameters.begin.cs
      set: inside_record_parameter_list
    - include: else_pop

  inside_record_parameter_list:
    - clear_scopes: 1
    - meta_scope: meta.record.parameters.cs
    - include: inside_method_parameter_list

  record_base:
    - match: ':'
      scope: punctuation.separator.type.cs
      set: inside_record_base
    - match: (?=where\b)
      set: type_constraints
    - include: else_pop

  inside_record_base:
    - clear_scopes: 1
    - meta_scope: meta.record.base.cs
    - include: inherited_classes

  record_block:
    - meta_content_scope: meta.record.cs
    - match: \{
      scope: punctuation.section.block.begin.cs
      set: inside_record_block
    - include: else_pop

  inside_record_block:
    - meta_scope: meta.record.body.cs meta.block.cs
    - include: inside_class_block

###[ STRUCT DECLARATIONS ]#####################################################

  struct_declaration:
    - match: struct\b
      scope: meta.struct.cs keyword.declaration.struct.cs
      push:
        - struct_block
        - struct_base
        - struct_parameter_list
        - type_parameter_list
        - struct_declaration_name

  struct_declaration_name:
    - match: '{{unreserved_name}}'
      scope: entity.name.struct.cs
      pop: 1
    - include: else_pop

  struct_parameter_list:
    - match: \(
      scope: punctuation.section.parameters.begin.cs
      set: inside_struct_parameter_list
    - include: else_pop

  inside_struct_parameter_list:
    - clear_scopes: 1
    - meta_scope: meta.struct.parameters.cs
    - include: inside_method_parameter_list

  struct_base:
    - match: ':'
      scope: punctuation.separator.type.cs
      set: inside_struct_base
    - match: (?=where\b)
      set: type_constraints
    - include: else_pop

  inside_struct_base:
    - clear_scopes: 1
    - meta_scope: meta.struct.base.cs
    - include: inherited_classes

  struct_block:
    - meta_content_scope: meta.struct.cs
    - match: \{
      scope: punctuation.section.block.begin.cs
      set: inside_struct_block
    - include: else_pop

  inside_struct_block:
    - meta_scope: meta.struct.body.cs meta.block.cs
    - include: inside_class_block

###[ TYPE DECLARATION SIGNATURES ]#############################################

  inherited_classes:
    - match: (?=where\b)
      set: type_constraints
    - match: ','
      scope: punctuation.separator.inherited-class.cs
    - include: namespace_variables
    - include: base_types
    - match: ({{unreserved_name}})?(\.)
      scope: meta.path.cs
      captures:
        1: support.type.cs
        2: punctuation.accessor.dot.cs
    - match: '{{unreserved_name}}'
      scope: entity.other.inherited-class.cs
      push:
        - inherited_class_argument_list
        - type_suffix
        - type_argument_list
    - include: else_pop

  inherited_class_argument_list:
    - match: \(
      scope: punctuation.section.group.begin.cs
      set: inside_inherited_class_argument_list
    - include: else_pop

  inside_inherited_class_argument_list:
    - meta_include_prototype: false
    - meta_scope: meta.constructor.arguments.cs meta.group.cs
    - match: \)
      scope: punctuation.section.group.end.cs
      pop: 1
    - include: arguments

  type_constraints:
    - meta_scope: meta.constraints.cs
    - match: (where)\b\s*({{unreserved_name}})?\s*(:)?
      captures:
        1: storage.modifier.where.cs
        2: support.type.cs
        3: punctuation.separator.type.cs
      push: primary_constraint
    - match: ','
      scope: punctuation.separator.types.cs
    - match: (new)\s*((\()\s*(\)))
      scope: meta.constructor.cs
      captures:
        1: keyword.operator.new.cs
        2: meta.group.cs
        3: punctuation.section.group.begin.cs
        4: punctuation.section.group.end.cs
    - include: type
    - include: else_pop

  primary_constraint:
    - match: (?:class|struct|unmanaged)\b
      scope: storage.type.cs
      pop: 1
    - include: else_pop

###[ MEMBER DECLARATIONS ]#####################################################

  member_declaration:
    - match: (?=[(@]|{{start_char}})
      push:
        - member_name
        - type_suffix
        - type_no_space

  member_name:
    - include: member_qualifiers
    - include: method_declaration
    - include: indexer_declaration
    - include: operator_declaration
    - include: field_declaration
    - include: else_pop

  member_qualifiers:
    - match: \.
      scope: punctuation.accessor.dot.cs
    - match: '{{unreserved_name}}(?=\s*(?:<[^(]*>\s*)?\.)'
      scope: entity.other.inherited-class.cs
      push:
        - type_suffix
        - type_argument_list

###[ CONSTRUCTOR MEMBER DECLARATIONS ]#########################################

  constructor_declaration:
    - match: '~{{unreserved_name}}(?=\s*\()'
      scope: meta.method.cs entity.name.function.destructor.cs
      push:
        - destructor_meta
        - method_body
        - method_parameter_list
    - match: '{{unreserved_name}}(?=\s*\()'
      scope: meta.method.cs entity.name.function.constructor.cs
      push:
        - constructor_meta
        - method_body
        - constructor_initializer
        - method_parameter_list

  constructor_meta:
    - meta_include_prototype: false
    - meta_scope: meta.constructor.cs
    - include: immediately_pop

  constructor_initializer:
    - match: ':'
      scope: punctuation.separator.function.cs
      set: inside_constructor_initializer
    - include: else_pop

  inside_constructor_initializer:
    - match: ((?:(this)|(base))\s*)(\()
      captures:
        1: meta.initializer.cs
        2: variable.language.this.cs
        3: variable.language.super.cs
        4: meta.initializer.arguments.cs meta.group.cs punctuation.section.group.begin.cs
      set: inside_constructor_initializer_argument_list
    - include: else_pop

  inside_constructor_initializer_argument_list:
    - meta_content_scope: meta.initializer.arguments.cs meta.group.cs
    - match: \)
      scope: meta.initializer.arguments.cs meta.group.cs punctuation.section.group.end.cs
      pop: 1
    - include: arguments

  destructor_meta:
    - meta_include_prototype: false
    - meta_scope: meta.destructor.cs
    - include: immediately_pop

###[ DELEGATE MEMBER DECLARATIONS ]############################################

  delegate_declaration:
    - match: delegate\b(?!\s*\*)
      scope: meta.delegate.cs keyword.declaration.delegate.cs
      push:
        - delegate_parameter_list
        - type_parameter_list
        - delegate_declaration_name
        - expect_type

  delegate_declaration_name:
    - match: '{{name}}'
      scope: entity.name.type.delegate.cs
      pop: 1
    - include: else_pop

  delegate_parameter_list:
    - meta_content_scope: meta.delegate.cs
    - match: \(
      scope: punctuation.section.parameters.begin.cs
      set: inside_delegate_parameter_list
    - include: else_pop

  inside_delegate_parameter_list:
    - meta_scope: meta.delegate.parameters.cs
    - include: inside_method_parameter_list

###[ EVENT MEMBER DECLARATIONS ]###############################################

  event_declaration:
    - match: event\b
      scope: meta.event.cs keyword.declaration.event.cs
      push:
        - event_declaration_meta
        - event_declaration_initializer
        - event_declaration_name
        - expect_type

  event_declaration_meta:
    - meta_include_prototype: false
    - meta_scope: meta.event.cs
    - include: immediately_pop

  event_declaration_name:
    - meta_include_prototype: false
    - include: member_qualifiers
    - match: '{{unreserved_name}}'
      scope: variable.other.member.cs
      pop: 1
    - include: else_pop

  event_declaration_initializer:
    - match: \{
      scope: punctuation.section.block.begin.cs
      set: inside_event_accessor_declaration
    - match: (?=\S)
      set: inside_field_declarations

  inside_event_accessor_declaration:
    - meta_scope: meta.accessors.cs meta.block.cs
    - match: \}
      scope: punctuation.section.block.end.cs
      pop: 1
    - include: stray_close_bracket
    - include: terminators
    - include: attributes
    - match: add\b
      scope: meta.method.cs keyword.declaration.function.accessor.add.cs
      push: method_body
    - match: remove\b
      scope: meta.method.cs keyword.declaration.function.accessor.remove.cs
      push: method_body
    - include: stray_names

###[ EXTENSION MEMBER DECLARATIONS ]###########################################

  extension_declaration:
    - match: extension\b
      scope: meta.extension.cs keyword.declaration.trait.cs
      push:
        - extension_block
        - extension_base
        - extension_parameter_list
        - type_parameter_list

  extension_parameter_list:
    - match: \(
      scope: punctuation.section.parameters.begin.cs
      set: inside_extension_parameter_list
    - include: else_pop

  inside_extension_parameter_list:
    - clear_scopes: 1
    - meta_scope: meta.extension.parameters.cs
    - include: inside_method_parameter_list

  extension_base:
    - match: ':'
      scope: punctuation.separator.type.cs
      set: inside_extension_base
    - match: (?=where\b)
      set: type_constraints
    - include: else_pop

  inside_extension_base:
    - clear_scopes: 1
    - meta_scope: meta.extension.base.cs
    - include: inherited_classes

  extension_block:
    - meta_content_scope: meta.extension.cs
    - match: \{
      scope: punctuation.section.block.begin.cs
      set: inside_extension_block
    - include: else_pop

  inside_extension_block:
    - meta_scope: meta.extension.body.cs meta.block.cs
    - match: \}
      scope: punctuation.section.block.end.cs
      pop: 1
    - include: stray_close_bracket
    - include: attributes
    - include: modifiers
    - include: member_declaration
    - include: code_block_in

###[ FIELD MEMBER DECLARATIONS ]###############################################

  field_declaration:
    - match: '{{unreserved_name}}'
      scope: variable.other.member.cs
      set: field_body

  field_body:
    # property
    - match: \{
      scope: punctuation.section.block.begin.cs
      set: inside_field_accessor_declaration
    - match: =>
      scope: keyword.declaration.function.accessor.get.cs
      set: expression
    # field
    - match: (?=\S)
      set: inside_field_declarations

  inside_field_accessor_declaration:
    - meta_scope: meta.accessors.cs meta.block.cs
    - match: \}
      scope: punctuation.section.block.end.cs
      set: field_accessor_initializer
    - include: stray_close_bracket
    - include: terminators
    - include: attributes
    - match: '{{visibility}}'
      scope: storage.modifier.access.cs
    - match: readonly\b
      scope: storage.modifier.cs
    - match: init\b
      scope: meta.method.cs keyword.declaration.function.accessor.init.cs
      push: method_body
    - match: get\b
      scope: meta.method.cs keyword.declaration.function.accessor.get.cs
      push: method_body
    - match: set\b
      scope: meta.method.cs keyword.declaration.function.accessor.set.cs
      push: method_body
    - include: stray_names

  field_accessor_initializer:
    - match: \s*(=)
      captures:
        1: keyword.operator.assignment.cs
      set: assignment_value
    - include: noeol_pop

  inside_field_declarations:
    - include: member_qualifiers
    - match: '{{unreserved_name}}'
      scope: variable.other.member.cs
    - match: ','
      scope: punctuation.separator.variables.cs
    - include: assignment_expressions
    - include: else_pop

###[ INDEXER DECLARATIONS ]####################################################

  indexer_declaration:
    - match: this\b
      scope: meta.indexer.cs variable.language.this.cs
      set:
        - indexer_body
        - indexer_parameter_list

  indexer_parameter_list:
    - match: \[
      scope: punctuation.section.brackets.begin.cs
      set: inside_indexer_parameter_list
    - match: (?=\S)
      fail: member_declaration

  inside_indexer_parameter_list:
    - clear_scopes: 1
    - meta_scope: meta.indexer.parameters.cs meta.brackets.cs
    - match: \]
      scope: punctuation.section.brackets.end.cs
      pop: 1
    - include: method_parameters

  indexer_body:
    - meta_content_scope: meta.indexer.cs
    - match: \{
      scope: punctuation.section.block.begin.cs
      set: inside_indexer_accessor_declaration
    - match: =>
      scope: meta.indexer.cs keyword.declaration.function.accessor.get.cs
      set: indexer_expression
    - include: else_pop

  inside_indexer_accessor_declaration:
    - meta_scope: meta.indexer.accessors.cs meta.block.cs
    - match: \}
      scope: punctuation.section.block.end.cs
      pop: 1
    - include: stray_close_bracket
    - include: terminators
    - include: attributes
    - match: '{{visibility}}'
      scope: storage.modifier.access.cs
    - match: get\b
      scope: meta.method.cs keyword.declaration.function.accessor.get.cs
      push: method_body
    - match: set\b
      scope: meta.method.cs keyword.declaration.function.accessor.set.cs
      push: method_body
    - include: stray_names

  indexer_expression:
    - meta_content_scope: meta.indexer.body.cs
    - include: expression

###[ METHOD MEMBER DECLARATIONS ]##############################################

  method_declaration:
    - match: '{{unreserved_name}}(?=\s*(?:<[^(]*>\s*)?\()'
      scope: meta.method.cs entity.name.function.cs
      set:
        - method_body
        - method_parameter_list
        - type_parameter_list

  method_parameter_list:
    - match: \(
      scope: punctuation.section.parameters.begin.cs
      set: inside_method_parameter_list
    - include: else_pop

  inside_method_parameter_list:
    - clear_scopes: 1
    - meta_scope: meta.method.parameters.cs
    - match: \)
      scope: punctuation.section.parameters.end.cs
      pop: 1
    - include: method_parameters

  method_parameters:
    - match: ','
      scope: punctuation.separator.parameter.cs
    - match: (?=[;{}]|=>)
      pop: 1
    - match: (?=\S)
      push:
        - assignment_expression
        - method_param_name
        - type_no_space
        - method_param_modifier

  method_param_modifier:
    - include: attributes
    - match: '{{method_param_type_modifier}}'
      scope: storage.modifier.parameter.cs
    - include: else_pop

  method_param_name:
    - match: '{{unreserved_name}}'
      scope: variable.parameter.cs
      pop: 1
    - include: else_pop

  method_body:
    - meta_content_scope: meta.method.cs
    - match: (?=where\b)
      push: type_constraints
    - match: \{
      scope: punctuation.section.block.begin.cs
      set: inside_method_block
    - match: =>
      scope: meta.method.cs keyword.declaration.function.arrow.cs
      set: inside_method_expression
    - include: else_pop

  inside_method_block:
    - meta_scope: meta.method.body.cs meta.block.cs
    - match: \}
      scope: punctuation.section.block.end.cs
      pop: 1
    - include: stray_close_bracket
    - include: code_block_in

  inside_method_expression:
    - meta_content_scope: meta.method.body.cs
    - include: expression

###[ OPERATOR DECLARATIONS ]###################################################

  conversion_declaration:
    - match: operator\b
      scope: meta.method.cs keyword.declaration.operator.cs
      push:
        - method_body
        - method_parameter_list
        - operator_type

  operator_type:
    - match: (?=\S)
      set: inside_operator_type

  inside_operator_type:
    - include: type_common_except_bare_custom_type
    - match: '{{unreserved_name}}'
      scope: support.type.cs
    - include: noeol_pop

  operator_declaration:
    - match: operator\b
      scope: meta.method.cs keyword.declaration.operator.cs
      set:
        - method_body
        - method_parameter_list
        - operator_name

  operator_name:
    # overloadable unary and binary operators
    - match: (?:\+\+|--|<<|>>>?|<=?|>=?|==|!=|[-+*/%&|^~!]|false|true)(?=[\s(])
      scope: entity.name.function.cs
      pop: 1
    # illegal operator tokens
    - match: '[^\s(};]+'
      scope: invalid.illegal.operator.cs
      pop: 1
    - include: else_pop

###[ VAR DECLARATIONS ]########################################################

  var_declaration:
    - match: var\b
      scope: storage.type.cs
      set: var_declarator
    - match: (?=\S)
      set: [variable_declaration_name, type_no_space]

  var_declarator:
    - include: tuple
    - include: variable_declaration_name

  variable_declaration_name:
    - match: _\b
      scope: variable.language.anonymous.cs
      pop: 1
    - match: '{{unreserved_name}}'
      scope: variable.other.cs
      pop: 1
    - include: else_pop

  variable_declaration_list:
    - match: _\b
      scope: variable.language.anonymous.cs
    - match: '{{unreserved_name}}'
      scope: variable.other.cs
    - match: ','
      scope: punctuation.separator.variables.cs
    - include: assignment_expressions
    - include: else_pop

###[ STATEMENTS ]##############################################################

  code_block_in:
    - include: terminators
    - match: (?=\S)
      push: line_of_code

  line_of_code:
    - include: statement_block
    # language keywords
    - match: else\s+if\b
      scope: keyword.control.conditional.elseif.cs
      set: maybe_expression_group
    - match: else\b
      scope: keyword.control.conditional.else.cs
    - match: if\b
      scope: keyword.control.conditional.if.cs
      set: maybe_expression_group
    - match: switch\b
      scope: meta.switch.cs keyword.control.conditional.switch.cs
      set: [switch_block, maybe_expression_group]
    # loop statements
    - match: do\b
      scope: keyword.control.loop.do.cs
    - match: foreach\b
      scope: keyword.control.loop.foreach.cs
      set: foreach_group
    - match: for\b
      scope: keyword.control.loop.for.cs
      set: for_group
    - match: while\b
      scope: keyword.control.loop.while.cs
      set: maybe_expression_group
    - match: try\b
      scope: keyword.control.exception.try.cs
      set: [finally_block, catch_expr, try_block]
    - match: (using)\s*(\()
      captures:
        1: keyword.declaration.using.cs
        2: meta.group.cs punctuation.section.group.begin.cs
      set: [using_block, line_of_code]
    - match: using\b
      scope: keyword.declaration.using.cs
      push:
        - using_meta
        - variable_declaration_list
        - var_declaration
    - match: (fixed)\s*(\()
      captures:
        1: keyword.control.other.fixed.cs
        2: meta.group.cs punctuation.section.group.begin.cs
      set: [expression_block, line_of_code]
    - match: (lock)\s*(\()
      captures:
        1: keyword.control.other.lock.cs
        2: meta.group.cs punctuation.section.group.begin.cs
      set: [expression_block, line_of_code]
    - match: (?:return|yield\s+return)\b
      scope: keyword.control.flow.return.cs
      set: expression
    - match: (continue|break|yield\s+break)\b\s*(;)?
      captures:
        1: keyword.control.flow.break.cs
        2: punctuation.terminator.statement.cs
      pop: 1
    - match: throw\b
      scope: keyword.control.flow.throw.cs
      set: expression
    - match: (goto)\s+(case)\b
      captures:
        1: keyword.control.flow.goto.cs
        2: keyword.control.conditional.case.cs
      set: expression
    - match: (goto)\s+({{name}})\s*(;)
      captures:
        1: keyword.control.flow.goto.cs
        2: constant.other.label.cs
        3: punctuation.terminator.statement.cs
      pop: 1
    - include: keywords
    # C#7/9, nested method
    - match: (?=(?:(?:async|ref|static)\s+)*{{namespaced_name}}{{type_suffix}}\s+{{namespaced_name}}\s*\()
      set:
        - include: terminators
        - include: modifiers
        - include: member_declaration
        - match: ''
          pop: 1
    - match: const\b
      scope: storage.modifier.cs
    - match: dynamic\b
      scope: storage.type.cs
      set:
        - variable_initializer
        - variable_declaration_name
    - match: var\b
      scope: storage.type.cs
      set:
        - variable_declaration_list
        - var_declarator
    - match: (?=\([^)]*\)\s*{{name}}\s*[(=])
      set:
        - local_name
        - type_tuple
    - match: (ref\s+(?:readonly\s+)?)?\b(?={{namespaced_name}}{{type_suffix}}\s+{{name}}(?!\s*(?:[(:])))
      captures:
        1: storage.modifier.cs
      set: [variable_declaration_list, type_no_space]
    - match: ({{name}})\s*({{colon}})
      captures:
        1: entity.name.label.cs
        2: punctuation.separator.cs
      pop: 1
    - include: namespace_variables
    - match: ({{name}})\s+({{name}})
      captures:
        1: support.type.cs
        2: variable.other.cs
      set: variable_declaration_list
    - match: (?=\S)
      set: expression

  local_name:
    - match: '{{unreserved_name}}(?=\s*\()'
      scope: meta.method.cs entity.name.function.constructor.cs
      set:
        - method_body
        - method_parameter_list
    - match: (?=\S)
      set:
        - variable_initializer
        - variable_declaration_name

  expression_block:
    - meta_content_scope: meta.group.cs
    - match: \)
      scope: meta.group.cs punctuation.section.group.end.cs
      set:
        - match: \{
          scope: punctuation.section.block.begin.cs
          set:
            - meta_scope: meta.block.cs
            - match: \}
              scope: punctuation.section.block.end.cs
              pop: 1
            - include: code_block_in
        - match: (?=\S)
          set: line_of_code

  using_block:
    - meta_content_scope: meta.group.cs
    - match: \)
      scope: meta.group.cs punctuation.section.group.end.cs
      set:
        - match: \{
          scope: punctuation.section.block.begin.cs
          set:
            - meta_scope: meta.block.cs
            - match: \}
              scope: punctuation.section.block.end.cs
              pop: 1
            - include: code_block_in
        - include: else_pop
    - include: else_pop

###[ CONDITIONAL STATEMENTS ]##################################################

  switch_block:
    - meta_content_scope: meta.switch.cs
    - match: \{
      scope: punctuation.section.block.begin.cs
      set: inside_switch_block
    - include: else_pop

  inside_switch_block:
    - meta_scope: meta.switch.body.cs meta.block.cs
    - match: \}
      scope: punctuation.section.block.end.cs
      pop: 1
    - match: \b((default)\s*)({{colon}})
      captures:
        1: meta.case.pattern.cs
        2: keyword.control.conditional.default.cs
        3: meta.case.cs punctuation.separator.case-statement.cs
    - match: \bcase\b
      scope: meta.case.cs keyword.control.conditional.case.cs
      push:
        - case_pattern
        - expect_pattern
    - include: code_block_in

  case_pattern:
    - meta_content_scope: meta.case.pattern.cs
    - match: \bwhen\b
      scope: meta.case.guard.cs keyword.control.conditional.when.cs
      set: inside_case_guard
    - include: inside_case_guard

  inside_case_guard:
    - meta_content_scope: meta.case.guard.cs
    - match: '{{colon}}'
      scope: meta.case.cs punctuation.separator.case-statement.cs
      pop: 1
    - include: expression

###[ EXCEPTION STATEMENTS ]####################################################

  try_block:
    - include: statement_block
    - include: else_pop

  catch_expr:
    - match: '(catch)\s*(\()'
      captures:
        1: keyword.control.exception.catch.cs
        2: meta.group.cs punctuation.section.group.begin.cs
      push: [catch_block, var_declaration]
    - match: 'catch\b'
      scope: keyword.control.exception.catch.cs
      push: trycatch_block
    - include: else_pop

  catch_block:
    - meta_content_scope: meta.group.cs
    - match: \)
      scope: meta.group.cs punctuation.section.group.end.cs
      set: catch_when

  catch_when:
    - match: when\b
      scope: keyword.control.exception.when.cs
      set:
        - match: \(
          scope: punctuation.section.group.begin.cs
          set:
            - meta_scope: meta.group.cs
            - match: \)
              scope: punctuation.section.group.end.cs
              set: trycatch_block
            - include: expression
        - match: (?=\S)
          set: trycatch_block
    - match: '(?=\S)'
      set: trycatch_block

  finally_block:
    - meta_scope: meta.block.trycatch.cs
    - match: finally\b
      scope: keyword.control.exception.finally.cs
      set: trycatch_block
    - include: else_pop

  trycatch_block:
    - include: statement_block
    - include: else_pop

###[ FOR STATEMENTS ]##########################################################

  for_group:
    - match: \(
      scope: punctuation.section.group.begin.cs
      set:
        - for_iteration
        - expression
        - for_separator
        - expression
        - for_separator
        - variable_declaration_list
        - for_declaration
    - include: else_pop

  for_declaration:
    - match: (?={{name}}\s*=)
      pop: 1
    - include: var_declaration

  for_separator:
    - match: ';'
      scope: punctuation.terminator.statement.cs
      pop: 1
    - include: else_pop

  for_iteration:
    - meta_scope: meta.group.cs
    - match: \)
      scope: punctuation.section.group.end.cs
      pop: 1
    - match: ','
      scope: punctuation.separator.expression.cs
      push: expression
    - include: else_pop

  foreach_group:
    - match: \(
      scope: punctuation.section.group.begin.cs
      set:
        - inside_expression_group
        - foreach_in
        - var_declaration
    - include: else_pop

  foreach_in:
    - match: in\b
      scope: keyword.control.loop.in.cs
      set: expression
    - include: else_pop

  maybe_statement_block:
    - include: statement_block
    - include: else_pop

  statement_block:
    - match: \{
      scope: punctuation.section.block.begin.cs
      set: inside_statement_block

  inside_statement_block:
    - meta_scope: meta.block.cs
    - match: \}
      scope: punctuation.section.block.end.cs
      pop: 1
    - include: code_block_in

###[ EXPRESSIONS ]#############################################################

  constant_expression:
    - match: (?=[,;)\]}])
      pop: 1
    - include: constant_parens
    - include: expression_common

  expressions:
    - match: (?=\S)
      push: expression

  expression:
    - match: (?=[,;)\]{}])
      pop: 1
    - include: parens
    - include: lambdas
    - include: expression_common

  expression_common:
    # accessors and operators (Note: order matters!)
    - match: ->
      scope: punctuation.accessor.arrow.cs
      push: maybe_pointer
    - match: '(?x: << | >>>? | \?\? | [-+*/%|&^] )='
      scope: keyword.operator.assignment.augmented.cs
      push: maybe_pointer
    - match: '(?x: \+\+? | --? | [*/%] )'
      scope: keyword.operator.arithmetic.cs
      push: maybe_pointer
    - match: '(?x: && | \|\| | !(?!=) )'
      scope: keyword.operator.logical.cs
      push: maybe_pointer
    - match: '(?x: << | >>>? | [|&^~] )'
      scope: keyword.operator.bitwise.cs
      push: maybe_pointer
    - match: '(?x: <=? | >=? | == | != )'
      scope: keyword.operator.comparison.cs
      push: maybe_pointer
    - match: =
      scope: keyword.operator.assignment.cs
      push: maybe_pointer
    - match: \.\.
      scope: keyword.operator.range.cs
      push: maybe_pointer
    - match: \.
      scope: punctuation.accessor.dot.cs
      push: maybe_pointer
    - match: \?\?
      scope: keyword.operator.null-coalescing.cs
      push: maybe_pointer
    - match: \?\.
      scope: punctuation.accessor.null-coalescing.cs
      push: maybe_pointer
    - match: (\?)?\s*(\[)
      captures:
        1: keyword.operator.null-coalescing.cs
        2: meta.brackets.cs punctuation.section.brackets.begin.cs
      push: inside_item_access
    - match: \?
      scope: keyword.operator.ternary.cs
      push:
        - inside_ternary_expression
        - maybe_pointer
    # keywords
    - match: '{{sql_keywords}}'
      scope: keyword.other.sql.cs
    - include: keywords
    - include: switch_expressions
    - include: base_types
    - include: constants
    - include: characters
    - include: numbers
    - include: strings
    # language variables
    - match: _\b
      scope: variable.language.anonymous.cs
    - match: value\b
      scope: variable.language.cs
    - include: namespace_variables
    # expressions
    - match: '{{name}}(?={{generic_declaration}}\s*\.)'
      scope: support.type.cs
      push: type_argument_list
    - match: (?:(?:(?:(System)(\.))?(Text)(\.))?(RegularExpressions)(\.))?(Regex)(\.)(Match|IsMatch|Replace)(?=\s*\()
      captures:
        1: variable.other.cs
        2: punctuation.accessor.dot.cs
        3: variable.other.cs
        4: punctuation.accessor.dot.cs
        5: variable.other.cs
        6: punctuation.accessor.dot.cs
        7: support.type.cs
        8: punctuation.accessor.dot.cs
        9: meta.function-call.identifier.cs variable.function.cs
      push: regex_function_call_argument_list
    - match: '{{name}}(?={{generic_declaration}}?\s*\()'
      scope: meta.function-call.identifier.cs variable.function.cs
      push:
        - function_call_argument_list
        - type_argument_list
    - match: '{{name}}'
      scope: variable.other.cs
    - match: '@'
      scope: invalid.illegal.reserved-char.cs

  inside_ternary_expression:
    - match: ':'
      scope: keyword.operator.ternary.cs
      pop: 1
    - include: expression

  keywords:
    - include: instantiations
    - include: modifiers
    - include: funcptr_types
    - match: delegate\b
      scope: keyword.declaration.delegate.cs
      push: maybe_statement_block
    - match: this\b
      scope: variable.language.this.cs
      push:
        - member_access
        - item_access
    - match: base\b
      scope: variable.language.super.cs
      push:
        - member_access
        - item_access
    - match: await\b
      scope: keyword.control.flow.await.cs
    - match: (?:return|yield\s+return)\b
      scope: keyword.control.flow.return.cs
    - match: throw\b
      scope: keyword.control.flow.throw.cs
    - match: (?:and|not|or)\b
      scope: keyword.operator.logical.cs
    - match: unsafe\b
      scope: keyword.other.cs
    - match: (?:checked|unchecked)\b
      scope: keyword.other.cs
      push: maybe_expression_group
    - match: as\b
      scope: keyword.operator.cast.cs
      push: expect_type
    - match: is\b
      scope: keyword.operator.comparison.type.cs
      push: expect_pattern
    - match: nameof\b
      scope: keyword.other.cs
      push: maybe_nameof_group
    - match: (?:sizeof|typeof|default)\b
      scope: keyword.other.cs
      push: maybe_type_group

###[ ASSIGNMENT EXPRESSIONS ]##################################################

  assignment_expressions:
    - match: =
      scope: keyword.operator.assignment.cs
      push: assignment_value

  assignment_expression:
    - match: =
      scope: keyword.operator.assignment.cs
      set: assignment_value
    - include: else_pop

  assignment_value:
    - match: \{
      scope: meta.braces.cs punctuation.section.braces.begin.cs
      set: inside_variable_initializer
    - match: (?=\S)
      set:
        - expression
        - maybe_pointer

###[ CONSTANT CAST, GROUP AND TUPLE EXPRESSIONS ]##############################

  constant_parens:
    # without lambdas for use in case guards
    - match: (?=\()
      branch_point: constant_parens
      branch:
        - constant_cast
        - constant_group
        - tuple

  constant_cast:
    - meta_include_prototype: false
    - match: \(
      scope: punctuation.section.group.begin.cs
      set:
        - after_constant_cast
        - inside_constant_cast
        - expect_type

  inside_constant_cast:
    - meta_scope: meta.cast.cs meta.group.cs
    - match: \)
      scope: punctuation.section.group.end.cs
      pop: 1
    - match: (?=\S)
      fail: constant_parens

  after_constant_cast:
    # cast expressions may be followed by:
    # - `!`     : unary operator
    # - `~`     : unary operator
    # - `(`     : cast, lambda or group expression
    # - literal : variable, type or method
    - match: (?=base\b|this\b|{{unreserved_name}}|[!~(])
      pop: 1
    - match: (?=\S)
      fail: constant_parens

  constant_group:
    - meta_include_prototype: false
    - match: \(
      scope: punctuation.section.group.begin.cs
      set:
        - inside_constant_group
        - constant_expression
        - maybe_pointer

  inside_constant_group:
    - meta_scope: meta.group.cs
    - match: \)
      scope: punctuation.section.group.end.cs
      pop: 1
    - match: (?=\S)
      fail: constant_parens

###[ CAST, GROUP, LAMBDA AND TUPLE EXPRESSIONS ]###############################

  parens:
    - match: (?=\()
      branch_point: parens
      branch:
        - lambda
        - cast
        - group
        - tuple

  cast:
    - meta_include_prototype: false
    - match: \(
      scope: punctuation.section.group.begin.cs
      set:
        - after_cast
        - inside_cast
        - expect_type

  inside_cast:
    - meta_scope: meta.cast.cs meta.group.cs
    - match: \)
      scope: punctuation.section.group.end.cs
      pop: 1
    - match: (?=\S)
      fail: parens

  after_cast:
    # cast expressions may be followed by:
    # - `!`     : unary operator
    # - `~`     : unary operator
    # - `(`     : cast, lambda or group expression
    # - literal : variable, type or method
    - match: (?=base\b|this\b|{{unreserved_name}}|[!~(])
      pop: 1
    - match: (?=\S)
      fail: parens

  group:
    - meta_include_prototype: false
    - match: \(
      scope: punctuation.section.group.begin.cs
      set:
        - inside_group
        - expression
        - maybe_pointer

  inside_group:
    - meta_scope: meta.group.cs
    - match: \)
      scope: punctuation.section.group.end.cs
      pop: 1
    - match: (?=\S)
      fail: parens

  lambda:
    - meta_include_prototype: false
    - match: \(
      scope: punctuation.section.group.begin.cs
      set: inside_lambda_parameter_list

  inside_lambda_parameter_list:
    - meta_scope: meta.function.anonymous.parameters.cs meta.group.cs
    - match: \)
      scope: punctuation.section.group.end.cs
      set: lambda_arrow
    - include: attributes
    - match: ','
      scope: punctuation.separator.parameter.cs
    - match: '{{method_param_type_modifier}}(?=\s)'
      scope: storage.modifier.parameter.cs
    - match: '{{name}}(?=\s*[\),/])'
      scope: variable.parameter.cs
    - match: (?={{cap_name}}{{type_suffix}}|{{base_type}})
      push: type_no_space
    - match: (?=\S)
      fail: parens

  lambda_arrow:
    - meta_content_scope: meta.function.anonymous.cs
    - match: =>
      scope: meta.function.anonymous.cs keyword.declaration.function.arrow.cs
      set: lambda_body
    - match: (?=\{)
      set: lambda_body
    - match: (?=\S)
      fail: parens

  tuple:
    - meta_include_prototype: false
    - match: \(
      scope: punctuation.section.sequence.begin.cs
      set:
        - inside_tuple
        - maybe_pointer

  inside_tuple:
    - meta_scope: meta.sequence.tuple.cs
    - match: \)
      scope: punctuation.section.sequence.end.cs
      pop: 1
    - match: ','
      scope: punctuation.separator.sequence.cs
      push: maybe_pointer
    - match: '{{colon}}'
      scope: keyword.operator.assignment.cs
    - match: (?=(?!{{reserved}}\b){{namespaced_name}}{{type_suffix}}?\s+{{name}})
      push: var_declaration
    - include: expression

###[ GROUP EXPRESSIONS ]#######################################################

  maybe_expression_group:
    - match: \(
      scope: punctuation.section.group.begin.cs
      set: inside_expression_group
    - include: else_pop

  inside_expression_group:
    - meta_scope: meta.group.cs
    - match: \)
      scope: punctuation.section.group.end.cs
      pop: 1
    - include: expression

  maybe_nameof_group:
    - match: \(
      scope: punctuation.section.group.begin.cs
      set: inside_nameof_group
    - include: else_pop

  inside_nameof_group:
    - meta_scope: meta.group.cs
    - match: \)
      scope: punctuation.section.group.end.cs
      pop: 1
    - include: instance_variables
    # We don't if these are types of variables, so we guess that
    # uppercase names are types, and others are variables
    - match: (?=(?!{{base_type}})\p{Ll}){{name}}(?=\s*\))
      scope: variable.other.cs
    - include: type
    - include: stray_names

  maybe_type_group:
    - match: \(
      scope: punctuation.section.group.begin.cs
      set: inside_type_group
    - include: else_pop

  inside_type_group:
    - meta_scope: meta.group.cs
    - match: \)
      scope: punctuation.section.group.end.cs
      pop: 1
    - include: type
    - include: stray_names

###[ FUNCTION CALL EXPRESSIONS ]###############################################

  regex_function_call_argument_list:
    - meta_content_scope: meta.function-call.identifier.cs
    - match: \(
      scope: punctuation.section.group.begin.cs
      set: inside_regex_function_call_argument_list
    - include: else_pop

  inside_regex_function_call_argument_list:
    - meta_scope: meta.function-call.arguments.cs meta.group.cs
    - match: \)
      scope: punctuation.section.group.end.cs
      pop: 1
    - match: (?=[@$]*")
      push: [immediately_pop, regex_string]
    - include: arguments

  function_call_argument_list:
    - meta_content_scope: meta.function-call.identifier.cs
    - match: \(
      scope: punctuation.section.group.begin.cs
      set: inside_function_call_argument_list
    - include: else_pop

  inside_function_call_argument_list:
    - meta_scope: meta.function-call.arguments.cs meta.group.cs
    - match: \)
      scope: punctuation.section.group.end.cs
      pop: 1
    - include: arguments

  arguments:
    - match: (?=[;)\]}])
      pop: 1
    - match: ','
      scope: punctuation.separator.argument.cs
    - match: out\b
      scope: storage.modifier.argument.cs
      push: out_argument
    - match: ref\b
      scope: storage.modifier.argument.cs
    - match: ({{name}})\s*({{colon}}|{{equal}})
      captures:
        1: variable.parameter.cs
        2: keyword.operator.assignment.cs
      push: maybe_pointer
    - include: expressions

  out_argument:
    - match: ref\b
      scope: storage.modifier.argument.cs
    - match: (?=(?!{{reserved}}\b){{namespaced_name}}{{type_suffix}}?\s+{{name}})
      push: var_declaration
    - include: else_pop

###[ INSTANTIATION EXPRESSIONS ]###############################################

  instantiations:
    - match: new\b
      scope: keyword.operator.new.cs
      push:
        - instantiation_meta
        - variable_initializer
        - instantiation_type
    - match: stackalloc\b
      scope: keyword.operator.stackalloc.cs
      push:
        - instantiation_meta
        - variable_initializer
        - instantiation_type
    - match: with(?=\s*\{)
      scope: keyword.operator.with.cs
      push: variable_initializer

  instantiation_meta:
    - meta_include_prototype: false
    - meta_scope: meta.instantiation.cs
    - include: immediately_pop

  instantiation_type:
    - meta_content_scope: meta.function-call.identifier.cs
    - match: (?={)
      pop: 1
    - match: \(
      scope: punctuation.section.group.begin.cs
      set: inside_function_call_argument_list
    - match: (?:(?:(?:(System)(\.))?(Text)(\.))?(RegularExpressions)(\.))?(Regex)\b
      scope: meta.path.cs
      captures:
        1: variable.other.cs
        2: punctuation.accessor.dot.cs
        3: variable.other.cs
        4: punctuation.accessor.dot.cs
        5: variable.other.cs
        6: punctuation.accessor.dot.cs
        7: meta.function-call.identifier.cs support.type.cs
      set: regex_function_call_argument_list
    - include: type

  variable_initializer:
    # collection or object initializer
    - match: \s*(\{)
      captures:
        1: meta.braces.cs punctuation.section.braces.begin.cs
      set: inside_variable_initializer
    - include: noeol_pop

  inside_variable_initializer:
    - meta_content_scope: meta.braces.cs
    - match: \}
      scope: meta.braces.cs punctuation.section.braces.end.cs
      pop: 1
    - match: \{
      scope: meta.braces.cs punctuation.section.braces.begin.cs
      push: inside_variable_initializer
    - match: ','
      scope: punctuation.separator.sequence.cs
    - match: ({{name}})\s*({{equal}})
      captures:
        1: variable.other.member.cs
        2: keyword.operator.assignment.cs
      push: maybe_pointer
    - include: expressions

###[ ITEM ACCESS EXPRESSIONS ]#################################################

  item_access:
    - match: \s*(\[)
      captures:
        1: meta.brackets.cs punctuation.section.brackets.begin.cs
      push: inside_item_access
    - include: noeol_pop

  inside_item_access:
    - meta_content_scope: meta.brackets.cs
    - match: \]
      scope: meta.brackets.cs punctuation.section.brackets.end.cs
      pop: 1
    - match: ','
      scope: punctuation.separator.sequence.cs
    - match: ({{name}})\s*({{colon}})
      captures:
        1: variable.parameter.cs
        2: keyword.operator.assignment.cs
    - include: expressions

  maybe_member_access:
    - match: \.
      scope: punctuation.accessor.dot.cs
      set: member_access
    - include: else_pop

  member_access:
    - include: member_qualifiers
    - match: '{{unreserved_name}}'
      scope: variable.other.member.cs
      set:
        - type_suffix
        - type_argument_list
    - include: else_pop

###[ LAMBDA EXPRESSIONS ]######################################################

  lambdas:
    - match: ({{name}})(\s+(=>))
      captures:
        1: meta.function.anonymous.parameters.cs variable.parameter.cs
        2: meta.function.anonymous.cs
        3: keyword.declaration.function.arrow.cs
      push: lambda_body

  lambda_body:
    - meta_content_scope: meta.function.anonymous.cs
    - match: \{
      scope: punctuation.section.block.begin.cs
      set: inside_lambda_block
    - match: (?=\S)
      set: inside_lambda_expression

  inside_lambda_block:
    - meta_scope: meta.function.anonymous.body.cs meta.block.cs
    - match: \}
      scope: punctuation.section.block.end.cs
      pop: 1
    - include: code_block_in

  inside_lambda_expression:
    - meta_content_scope: meta.function.anonymous.body.cs
    - include: expression

###[ SWITCH EXPRESSIONS ]######################################################

  switch_expressions:
    - match: switch\b
      scope: meta.switch.cs keyword.control.conditional.switch.cs
      push: switch_expression_block

  switch_expression_block:
    - meta_content_scope: meta.switch.cs
    - match: \{
      scope: punctuation.section.block.begin.cs
      set:
        - inside_switch_expression_block
        - switch_expression_case_pattern
        - expect_pattern
    - include: else_pop

  inside_switch_expression_block:
    - meta_scope: meta.switch.body.cs meta.block.cs
    - match: \}
      scope: punctuation.section.block.end.cs
      pop: 1
    - match: ','
      scope: punctuation.terminator.case-expression.cs
      push:
        - switch_expression_case_pattern
        - expect_pattern
    - include: expression

  switch_expression_case_pattern:
    - meta_content_scope: meta.case.pattern.cs
    - match: when\b
      scope: meta.case.guard.cs keyword.control.conditional.when.cs
      set: inside_switch_expression_case_guard
    - include: inside_switch_expression_case_guard

  inside_switch_expression_case_guard:
    - meta_content_scope: meta.case.guard.cs
    - match: =>
      scope: meta.case.cs punctuation.separator.case-expression.cs
      pop: 1
    - include: constant_expression

###[ TYPE PATTERNS ]###########################################################

  expect_pattern:
    - match: \{
      scope: punctuation.section.block.begin.cs
      set: inside_member_pattern
    - match: \(
      scope: punctuation.section.sequence.begin.cs
      set: inside_tuple
    - match: not\b
      scope: keyword.operator.logical.cs
    - match: var\b
      scope: storage.type.cs
    - match: '{{base_type}}'
      scope: storage.type.cs
      set:
        - maybe_member_pattern
        - maybe_member_access
        - type_suffix
    - match: '{{cap_name}}'
      scope: support.type.cs
      set:
        - maybe_member_pattern
        - maybe_member_access
        - type_suffix
        - type_argument_list
    - include: else_pop

  maybe_member_pattern:
    - match: \{
      scope: punctuation.section.block.begin.cs
      set: inside_member_pattern
    - include: else_pop

  inside_member_pattern:
    - meta_scope: meta.class.body.cs meta.block.cs
    - match: \}
      scope: punctuation.section.block.end.cs
      pop: 1
    - match: ','
      scope: punctuation.separator.property.cs
    - match: ({{name}})\s*(\.)
      captures:
        1: variable.other.member.cs
        2: punctuation.accessor.dot.cs
    - match: ({{name}})\s*({{colon}})?
      captures:
        1: variable.other.member.cs
        2: keyword.operator.assignment.cs
      push:
        - expression
        - expect_pattern

###[ TYPES ]###################################################################

  modifiers:
    - match: '{{modifiers}}'
      scope: storage.modifier.cs
    - match: '{{visibility}}'
      scope: storage.modifier.access.cs

  expect_type:
    - match: (?=\S)
      set: type_no_space

  type_no_space:
    - include: type
    - include: noeol_pop

  type:
    - include: type_common_except_bare_custom_type
    - match: '{{unreserved_name}}'
      scope: support.type.cs
    - match: \(
      scope: punctuation.section.sequence.begin.cs
      push: inside_type_tuple

  type_tuple:
    - match: \(
      scope: punctuation.section.sequence.begin.cs
      set: inside_type_tuple

  inside_type_tuple:
    - meta_scope: meta.sequence.tuple.cs
    - match: \)
      scope: punctuation.section.sequence.end.cs
      pop: 1
    - match: ','
      scope: punctuation.separator.sequence.cs
    - match: (?=\S)
      push: var_declaration

  type_common_except_bare_custom_type:
    - include: namespace_variables
    - include: funcptr_types
    - include: base_types
    - match: \s*(\[)
      captures:
        1: meta.brackets.cs punctuation.section.brackets.begin.cs
      push: inside_rank_specifier
    - match: \s*(\.)\s*
      captures:
        1: punctuation.accessor.dot.cs
    - match: '\*'
      scope: keyword.operator.pointer.cs
    - match: \s*(\?)
      captures:
        1: storage.type.nullable.cs
    - match: \s*(<)
      captures:
        1: meta.generic.cs punctuation.definition.generic.begin.cs
      push: inside_type_argument_list
    - match: (?=[]})>,;>:]|=>)
      pop: 1

  base_types:
    - match: '{{base_type}}'
      scope: storage.type.cs

  inside_rank_specifier:
    - meta_content_scope: meta.brackets.cs
    - match: \]
      scope: meta.brackets.cs punctuation.section.brackets.end.cs
      pop: 1
    - match: ','
      scope: punctuation.separator.sequence.cs
    - include: expressions

###[ TYPE PARAMETER LISTS ]####################################################

  type_argument_lists:
    - match: '<'
      scope: meta.generic.cs punctuation.definition.generic.begin.cs
      push: inside_type_argument_list

  type_argument_list:
    - match: '<'
      scope: meta.generic.cs punctuation.definition.generic.begin.cs
      set: inside_type_argument_list
    - include: else_pop

  inside_type_argument_list:
    - meta_content_scope: meta.generic.cs
    - include: type_arg_param_common
    - match: (?=\S)
      push: [type_suffix, type]

  type_parameter_list:
    - match: '<'
      scope: meta.generic.cs punctuation.definition.generic.begin.cs
      set: inside_type_parameter_list
    - include: else_pop

  inside_type_parameter_list:
    - meta_content_scope: meta.generic.cs
    - include: type_arg_param_common
    - match: '{{name}}'
      scope: variable.parameter.type.cs
      push: type_suffix

  type_arg_param_common:
    - match: '>'
      scope: meta.generic.cs punctuation.definition.generic.end.cs
      pop: 1
    - match: ','
      scope: punctuation.separator.type.cs
    - include: attributes
    - match: (?:in|out|ref|readonly)\b
      scope: storage.modifier.cs

  type_suffix:
    - meta_include_prototype: false
    - match: \s*{{type_suffix_capture}}
      captures:
        1: storage.type.nullable.cs
        2: meta.brackets.cs
        3: punctuation.section.brackets.begin.cs
        4: punctuation.separator.cs
        5: punctuation.section.brackets.end.cs
        6: keyword.operator.pointer.cs
      pop: 1
    - include: noeol_pop

###[ FUNCTION POINTER TYPES ]##################################################

  funcptr_types:
    # https://learn.microsoft.com/en-us/dotnet/csharp/language-reference/proposals/csharp-9.0/function-pointers
    - match: (delegate)\s*(\*)
      captures:
        1: keyword.declaration.delegate.cs
        2: keyword.operator.pointer.cs
      push:
        - funcptr_type_meta
        - funcptr_parameter_list
        - funcptr_type_modifier

  funcptr_type_meta:
    - meta_include_prototype: false
    - meta_scope: meta.type.funcptr.cs
    - include: immediately_pop

  funcptr_type_modifier:
    - match: \s*(managed)\b
      captures:
        1: storage.modifier.delegate.cs
      pop: 1
    - match: \s*(unmanaged)\b
      captures:
        1: storage.modifier.delegate.cs
      set: funcptr_type_calling_convention
    - include: noeol_pop

  funcptr_type_calling_convention:
    - match: \s*(\[)
      captures:
        1: meta.brackets.cs punctuation.section.brackets.begin.cs
      set: inside_funcptr_type_calling_convention
    - include: noeol_pop

  inside_funcptr_type_calling_convention:
    - meta_content_scope: meta.brackets.cs
    - match: \]
      scope: meta.brackets.cs punctuation.section.brackets.end.cs
      pop: 1
    - match: ','
      scope: punctuation.separator.type.cs
    - match: (?:Cdecl|Stdcall|Thiscall|Fastcall)\b
      scope: storage.modifier.funcptr.cs
    - include: type

  funcptr_parameter_list:
    - match: \s*(<)
      captures:
        1: meta.generic.cs punctuation.definition.generic.begin.cs
      set: inside_funcptr_parameter_list
    - include: noeol_pop

  inside_funcptr_parameter_list:
    - meta_content_scope: meta.generic.cs
    - match: '>'
      scope: meta.generic.cs punctuation.definition.generic.end.cs
      pop: 1
    - match: ','
      scope: punctuation.separator.type.cs
    - match: (?:in|out|ref|readonly)\b
      scope: storage.modifier.cs
    - include: type

###[ OPERATORS ]###############################################################

  maybe_pointer:
    - match: '[*&]'
      scope: keyword.operator.pointer.cs
      pop: 1
    - include: attributes
    - include: else_pop

  terminators:
    - match: ';'
      scope: punctuation.terminator.statement.cs

###[ VARIABLES ]###############################################################

  instance_variables:
    - match: this\b
      scope: variable.language.this.cs
    - match: base\b
      scope: variable.language.super.cs

  namespace_variables:
    - match: (?:(global)|({{name}}))\s*(::)
      scope: meta.path.cs
      captures:
        1: support.namespace.global.cs
        2: variable.namespace.cs
        3: punctuation.accessor.double-colon.namespace.cs

  stray_names:
    - match: '{{name}}'
      scope: invalid.illegal.unexpected-token.cs

###[ LITERALS ]################################################################

  characters:
    - match: (')(?:({{escape_base}})|({{escape_hex}})|({{escape_uni16}})|({{escape_uni32}})|([^'\\]))(')
      scope: meta.string.cs string.quoted.single.cs
      captures:
        1: punctuation.definition.string.begin.cs
        2: constant.character.escape.cs
        3: constant.character.escape.hex.cs
        4: constant.character.escape.unicode.16bit.cs
        5: constant.character.escape.unicode.32bit.cs
        6: constant.character.literal.cs
        7: punctuation.definition.string.end.cs
    - match: \'.*\'
      scope: invalid.illegal.character.cs

  constants:
    - match: false\b
      scope: constant.language.boolean.false.cs
    - match: true\b
      scope: constant.language.boolean.true.cs
    - match: null\b
      scope: constant.language.null.cs

  numbers:
    - match: (0[xX])([\h_]*\h)({{integer_suffix}})?
      scope: meta.number.integer.hexadecimal.cs
      captures:
        1: constant.numeric.base.cs
        2: constant.numeric.value.cs
        3: constant.numeric.suffix.cs
    - match: (0[bB])([01_]*[01])({{integer_suffix}})?
      scope: meta.number.integer.binary.cs
      captures:
        1: constant.numeric.base.cs
        2: constant.numeric.value.cs
        3: constant.numeric.suffix.cs
    - match: (\d{{dec_digits}}?)(?:(?:((\.){{dec_digits}})({{dec_exponent}})?|({{dec_exponent}}))({{float_suffix}})?|({{float_suffix}}))
      scope: meta.number.float.decimal.cs
      captures:
        1: constant.numeric.value.cs
        2: constant.numeric.value.cs
        3: punctuation.separator.decimal.cs
        4: constant.numeric.value.exponent.cs
        5: constant.numeric.value.exponent.cs
        6: constant.numeric.suffix.cs
        7: constant.numeric.suffix.cs
    - match: (\d{{dec_digits}}?)({{integer_suffix}})?
      scope: meta.number.integer.decimal.cs
      captures:
        1: constant.numeric.value.cs
        2: constant.numeric.suffix.cs

###[ REGULAR EXPRESSIONS ]#####################################################

  regex_string:
    - match: '"'
      scope: meta.string.cs string.quoted.double.cs punctuation.definition.string.begin.cs
      embed: scope:source.regexp.cs
      embed_scope: meta.string.cs string.quoted.double.cs source.regexp
      escape: '"'
      escape_captures:
        0: meta.string.cs string.quoted.double.cs punctuation.definition.string.end.cs
      pop: 1
    - match: '@"'
      scope: meta.string.cs string.quoted.double.verbatim.cs punctuation.definition.string.begin.cs
      embed: scope:source.regexp.cs
      embed_scope: meta.string.cs string.quoted.double.verbatim.cs source.regexp
      escape: '"'
      escape_captures:
        0: meta.string.cs string.quoted.double.verbatim.cs punctuation.definition.string.end.cs
      pop: 1
    - include: else_pop

###[ STRINGS ]#################################################################

  strings:
    # literal raw strings
    - match: '(""""+)'
      scope: punctuation.definition.string.begin.cs
      push: inside_raw_string
    - match: '"""'
      scope: punctuation.definition.string.begin.cs
      push:
        - inside_triple_quoted_raw_string
        - inside_triple_quoted_raw_string_syntax
    # literal quoted strings
    - match: '"'
      scope: punctuation.definition.string.begin.cs
      push: inside_string
    # interpolated raw format strings
    - match: '\${1}("""+)'
      scope: punctuation.definition.string.begin.cs
      push: inside_raw_format_string_1
    - match: '\${2}("""+)'
      scope: punctuation.definition.string.begin.cs
      push: inside_raw_format_string_2
    - match: '\${3}("""+)'
      scope: punctuation.definition.string.begin.cs
      push: inside_raw_format_string_3
    - match: '\${4}("""+)'
      scope: punctuation.definition.string.begin.cs
      push: inside_raw_format_string_4
    # interpolated quoted format strings
    - match: '\$"'
      scope: punctuation.definition.string.begin.cs
      push: inside_format_string
    # literal verbatim strings
    - match: '@"'
      scope: punctuation.definition.string.begin.cs
      push:
        - inside_verbatim_string
        - inside_verbatim_string_syntax
    # interpolated verbatim format strings
    - match: '(?:@\$|\$@)"'
      scope: punctuation.definition.string.begin.cs
      push:
        - inside_verbatim_format_string
        - inside_verbatim_format_string_syntax

###[ QUOTED STRINGS ]##########################################################

  inside_string:
    - meta_include_prototype: false
    - meta_scope: meta.string.cs string.quoted.double.cs
    - match: '"'
      scope: punctuation.definition.string.end.cs
      pop: 1
    - include: string_prototype
    - include: string_escapes
    - include: string_placeholder_escapes
    - include: string_placeholders
    - match: (\{)(\d+)
      captures:
        1: punctuation.definition.placeholder.begin.cs
        2: meta.number.integer.decimal.cs constant.numeric.value.cs
      push: inside_extended_string_placeholder
    - match: $\n?
      scope: invalid.illegal.unclosed-string.cs
      pop: 1

  inside_extended_string_placeholder:
    - meta_scope: constant.other.placeholder.cs
    - include: string_placeholder_end
    - include: string_placeholder_width
    - include: string_placeholder_format
    - match: '[^"}]+'
      scope: invalid.illegal.unexpected-character-in-placeholder.cs

  inside_format_string:
    - meta_include_prototype: false
    - meta_scope: meta.string.interpolated.cs string.quoted.double.cs
    - match: '"'
      scope: punctuation.definition.string.end.cs
      pop: 1
    - include: string_prototype
    - include: string_escapes
    - include: string_placeholder_escapes
    - match: \{
      scope: punctuation.section.interpolation.begin.cs
      push: inside_format_string_interpolation
    - match: \}
      scope: invalid.illegal.unescaped-placeholder.cs
    - match: $\n?
      scope: invalid.illegal.unclosed-string.cs
      pop: 1

  inside_format_string_interpolation:
    - clear_scopes: 1
    - meta_scope: meta.interpolation.cs
    - meta_content_scope: source.cs
    - match: \}
      scope: punctuation.section.interpolation.end.cs
      pop: 1
    - include: string_interpolation_width
    - include: string_placeholder_format
    - include: expression

  string_placeholder_format:
    - match: ':(?=")'
      scope: invalid.illegal.unclosed-string-placeholder.cs
      pop: 1
    - match: ':'
      scope: punctuation.separator.cs
      push: inside_string_placeholder_format

  inside_string_placeholder_format:
    - meta_scope: meta.format-spec.cs
    - meta_content_scope: constant.other.format-spec.cs
    - include: string_escapes
    - include: string_placeholder_escapes
    - match: (?=\})
      pop: 1
    - match: (?:[^}"\\](?:\\.)*)*(?=")
      scope: invalid.illegal.unclosed-string-placeholder.cs
      pop: 2
    - match: \{
      scope: invalid.illegal.unescaped-placeholder.cs

###[ VERBATIM STRINGS ]########################################################

  inside_verbatim_string:
    - meta_include_prototype: false
    - meta_scope: meta.string.cs string.quoted.double.verbatim.cs
    - include: verbatim_string_escapes
    - match: '"'
      scope: punctuation.definition.string.end.cs
      pop: 1
    - include: string_prototype
    - include: string_placeholder_escapes
    - include: string_placeholders
    - include: extended_verbatim_string_placeholders

  inside_verbatim_string_syntax:
    - meta_include_prototype: false
    - match: (?={{sql_indicator}})
      set: scope:source.sql
      with_prototype:
        - include: verbatim_string_escapes
        - match: (?=")
          pop: 1
        - include: string_prototype
        - include: string_placeholder_escapes
        - include: string_placeholders
        - include: extended_verbatim_string_placeholders
    - include: else_pop

  extended_verbatim_string_placeholders:
    - match: (\{)(\d+)
      captures:
        1: punctuation.definition.placeholder.begin.cs
        2: meta.number.integer.decimal.cs constant.numeric.value.cs
      push: inside_extended_verbatim_string_placeholder

  inside_extended_verbatim_string_placeholder:
    - meta_scope: constant.other.placeholder.cs
    - include: string_placeholder_end
    - include: string_placeholder_width
    - include: verbatim_string_placeholder_format
    - match: '[^"}]+'
      scope: invalid.illegal.unexpected-character-in-placeholder.cs

  inside_verbatim_format_string:
    - meta_include_prototype: false
    - meta_scope: meta.string.interpolated.cs string.quoted.double.verbatim.cs
    - include: verbatim_string_escapes
    - match: '"'
      scope: punctuation.definition.string.end.cs
      pop: 1
    - include: string_prototype
    - include: string_placeholder_escapes
    - include: verbatim_format_string_interpolations

  inside_verbatim_format_string_syntax:
    - meta_include_prototype: false
    - match: (?={{sql_indicator}})
      set: scope:source.sql
      with_prototype:
        - include: verbatim_string_escapes
        - match: (?=")
          pop: 1
        - include: string_prototype
        - include: string_placeholder_escapes
        - include: verbatim_format_string_interpolations
    - include: else_pop

  verbatim_format_string_interpolations:
    - match: \{
      scope: punctuation.section.interpolation.begin.cs
      push: inside_verbatim_format_string_interpolation
    - match: \}
      scope: invalid.illegal.unescaped-placeholder.cs

  inside_verbatim_format_string_interpolation:
    - clear_scopes: 1
    - meta_scope: meta.interpolation.cs
    - meta_content_scope: source.cs
    - match: \}
      scope: punctuation.section.interpolation.end.cs
      pop: 1
    - include: string_interpolation_width
    - include: verbatim_string_placeholder_format
    - include: expression

  verbatim_string_placeholder_format:
    - match: ':(?="(?!"))'
      scope: invalid.illegal.unclosed-string-placeholder.cs
      pop: 1
    - match: ':'
      scope: punctuation.separator.cs
      push: inside_verbatim_string_placeholder_format

  inside_verbatim_string_placeholder_format:
    - meta_scope: meta.format-spec.cs
    - meta_content_scope: constant.other.format-spec.cs
    - include: verbatim_string_escapes
    - include: string_placeholder_escapes
    - match: (?=\})
      pop: 1
    - match: \\(?:""|[^"])
      scope: constant.character.escape.cs
    - match: (?:[^}"]|"")*(?="(?!"))
      scope: invalid.illegal.unclosed-string-placeholder.cs
      pop: 2
    - match: \{
      scope: invalid.illegal.unescaped-placeholder.cs

  verbatim_string_escapes:
    - match: '""'
      scope: constant.character.escape.cs

###[ RAW STRINGS ]#############################################################

  inside_triple_quoted_raw_string:
    - meta_include_prototype: false
    - meta_scope: meta.string.cs string.quoted.double.block.cs
    - match: '"""'
      scope: punctuation.definition.string.end.cs
      pop: 1
    - include: string_prototype
    - include: string_placeholder_escapes
    - include: string_placeholders
    - include: extended_raw_string_placeholders

  inside_triple_quoted_raw_string_syntax:
    - meta_include_prototype: false
    - match: (?={{sql_indicator}})
      set: scope:source.sql
      with_prototype:
        - match: (?=""")
          pop: 1
        - include: string_prototype
    - include: else_pop

  inside_raw_string:
    - meta_include_prototype: false
    - meta_scope: meta.string.cs string.quoted.double.block.cs
    - match: \1
      scope: punctuation.definition.string.end.cs
      pop: 1
    - include: string_prototype
    - include: string_placeholder_escapes
    - include: string_placeholders
    - include: extended_raw_string_placeholders

  extended_raw_string_placeholders:
    - match: (\{)(\d+)
      captures:
        1: punctuation.definition.placeholder.begin.cs
        2: meta.number.integer.decimal.cs constant.numeric.value.cs
      push: inside_extended_raw_string_placeholder

  inside_extended_raw_string_placeholder:
    - meta_scope: constant.other.placeholder.cs
    - include: string_placeholder_end
    - include: string_placeholder_width
    - include: raw_string_placeholder_format
    - match: '[^"}]+'
      scope: invalid.illegal.unexpected-character-in-placeholder.cs

  inside_raw_format_string_1:
    - meta_include_prototype: false
    - meta_scope: meta.string.interpolated.cs string.quoted.double.block.cs
    - match: \1
      scope: punctuation.definition.string.end.cs
      pop: 1
    - include: string_prototype
    - match: \{{2,}|\}{1,}
      scope: invalid.illegal.unexpected-token.cs
    - match: \{
      scope: punctuation.section.interpolation.begin.cs
      push: inside_raw_format_string_interpolation_1

  inside_raw_format_string_interpolation_1:
    - clear_scopes: 1
    - meta_scope: meta.interpolation.cs
    - meta_content_scope: source.cs
    - match: \}
      scope: punctuation.section.interpolation.end.cs
      pop: 1
    - include: string_interpolation_width
    - include: raw_string_placeholder_format
    - include: expression

  inside_raw_format_string_2:
    - meta_include_prototype: false
    - meta_scope: meta.string.interpolated.cs string.quoted.double.block.cs
    - match: \1
      scope: punctuation.definition.string.end.cs
      pop: 1
    - include: string_prototype
    - match: \{{2}(?!\{)
      scope: punctuation.section.interpolation.begin.cs
      push: inside_raw_format_string_interpolation_2
    - match: \}{2,}
      scope: invalid.illegal.unexpected-token.cs

  inside_raw_format_string_interpolation_2:
    - clear_scopes: 1
    - meta_scope: meta.interpolation.cs
    - meta_content_scope: source.cs
    - match: \}{2}
      scope: punctuation.section.interpolation.end.cs
      pop: 1
    - include: string_interpolation_width
    - include: raw_string_placeholder_format
    - include: expression

  inside_raw_format_string_3:
    - meta_include_prototype: false
    - meta_scope: meta.string.interpolated.cs string.quoted.double.block.cs
    - match: \1
      scope: punctuation.definition.string.end.cs
      pop: 1
    - include: string_prototype
    - match: \{{3}(?!\{)
      scope: punctuation.section.interpolation.begin.cs
      push: inside_raw_format_string_interpolation_3
    - match: \}{3,}
      scope: invalid.illegal.unexpected-token.cs

  inside_raw_format_string_interpolation_3:
    - clear_scopes: 1
    - meta_scope: meta.interpolation.cs
    - meta_content_scope: source.cs
    - match: \}{3}
      scope: punctuation.section.interpolation.end.cs
      pop: 1
    - include: string_interpolation_width
    - include: raw_string_placeholder_format
    - include: expression

  inside_raw_format_string_4:
    - meta_include_prototype: false
    - meta_scope: meta.string.interpolated.cs string.quoted.double.block.cs
    - match: \1
      scope: punctuation.definition.string.end.cs
      pop: 1
    - include: string_prototype
    - match: \{{4}(?!\{)
      scope: punctuation.section.interpolation.begin.cs
      push: inside_raw_format_string_interpolation_4
    - match: \}{4,}
      scope: invalid.illegal.unexpected-token.cs

  inside_raw_format_string_interpolation_4:
    - clear_scopes: 1
    - meta_scope: meta.interpolation.cs
    - meta_content_scope: source.cs
    - match: \}{4}
      scope: punctuation.section.interpolation.end.cs
      pop: 1
    - include: string_interpolation_width
    - include: raw_string_placeholder_format
    - include: expression

  raw_string_placeholder_format:
    - match: ':'
      scope: punctuation.separator.cs
      push: inside_raw_string_placeholder_format

  inside_raw_string_placeholder_format:
    - meta_scope: meta.format-spec.cs
    - meta_content_scope: constant.other.format-spec.cs
    - match: (?=\})
      pop: 1
    - match: (?=")
      pop: 2
    - match: \\
      scope: invalid.illegal.lone-escape.cs
    - match: \{
      scope: invalid.illegal.unescaped-placeholder.cs

###[ STRING PROTOTYPES ]#######################################################

  string_escapes:
    # https://github.com/dotnet/csharpstandard/blob/standard-v6/standard/lexical-structure.md#6455-character-literals
    - match: '{{escape_base}}'
      scope: constant.character.escape.cs
    - match: '{{escape_hex}}'
      scope: constant.character.escape.hex.cs
    - match: '{{escape_uni16}}'
      scope: constant.character.escape.unicode.16bit.cs
    - match: '{{escape_uni32}}'
      scope: constant.character.escape.unicode.32bit.cs
    - match: \\
      scope: invalid.illegal.lone-escape.cs

  string_placeholder_escapes:
    - match: \{\{|\}\}
      scope: constant.character.escape.cs

  string_placeholders:
    - match: \{\h{8}-(?:\h{4}-){3}\h{12}\}
      scope: constant.other.guid.cs
    - match: (\{)(\d+)(?=")
      scope: constant.other.placeholder.cs
      captures:
        1: punctuation.definition.placeholder.begin.cs
        2: meta.number.integer.decimal.cs constant.numeric.value.cs invalid.illegal.unclosed-string-placeholder.cs

  string_placeholder_end:
    - match: (\})(\}(?!\}))?
      captures:
        1: punctuation.definition.placeholder.end.cs
        2: invalid.illegal.unescaped-placeholder.cs
      pop: 1
    - match: (?=")
      pop: 1

  string_placeholder_width:
    - match: \s*(?:(,)\s*((-?)\d+)\s*)?
      scope: meta.format-spec.cs
      captures:
        1: punctuation.separator.cs
        2: meta.number.integer.decimal.cs constant.numeric.value.cs
        3: keyword.operator.arithmetic.cs
        4: variable.other.cs

  string_interpolation_width:
    - match: \s*(?:(,)\s*(?:((-?)\d+)|({{name}}))\s*)?
      scope: meta.format-spec.cs
      captures:
        1: punctuation.separator.cs
        2: meta.number.integer.decimal.cs constant.numeric.value.cs
        3: keyword.operator.arithmetic.cs
        4: variable.other.cs

  string_prototype: []

###[ PROTOTYPES ]##############################################################

  else_pop:
    - match: (?=\S)
      pop: 1

  immediately_pop:
    - match: ''
      pop: 1

  noeol_pop:
    # immediately pop, but not before newlines
    - match: (?=[^\n])
      pop: 1

###[ VARIABLES ]###############################################################

variables:
  shebang_language: \bdotnet\s+run\b

  colon: :(?!:)
  equal: =(?![=>])

  # numbers
  dec_digits: (?:[\d_]*\d)
  dec_exponent: (?:[eE][-+]??{{dec_digits}})
  float_suffix: '[fFdDmM]'
  integer_suffix: '[uU][lL]?|[lL][uU]?'

  # characters
  escape_base: \\[0abfnrtv"'\\]
  escape_hex: \\x\h{1,4}
  escape_uni16: \\u\h{4}
  escape_uni32: \\U\h{8}

  modifiers: (?:abstract|async|const|explicit|extern|implicit|new|override|partial|readonly|ref|required|sealed|static|unsafe|virtual|volatile)\b
  visibility: (?:file|internal|private|protected|public)\b

  base_type: (?:bool|byte|sbyte|char|decimal|double|float|int|uint|nint|nuint|long|ulong|short|ushort|dynamic|object|string|void)\b
  type_suffix: (?:\s*(?:\[,*\]|\*|\?)*)
  generic_declaration: (?:\s*<[^={};]*>)

  brackets_capture: '((\[)(,*)(\]))'
  type_suffix_capture: '(\?)?{{brackets_capture}}?(?:\s*(\*))?'

  reserved: '(?:abstract|as|base|break|case|catch|checked|class|const|continue|default|delegate|do|else|enum|event|explicit|extern|finally|fixed|for|foreach|goto|if|implicit|in|interface|internal|is|lock|nameof|namespace|new|not|null|operator|out|override|params|private|protected|public|readonly|ref|required|return|sealed|sizeof|stackalloc|static|string|struct|switch|this|throw|try|typeof|unchecked|unsafe|using|virtual|volatile|while)'
  name: '(?:@?{{name_normal}})'
  namespaced_name: (?:(?:{{name}}{{generic_declaration}}?\s*\.\s*)*{{name}}{{generic_declaration}}?)

  unreserved_name: (?:@|(?!{{reserved}}\b|{{base_type}}\b)){{name_normal}}

  start_char: '(?:{{escape_uni16}}|{{escape_uni32}}|[_\p{L}])'
  other_char: '(?:{{escape_uni16}}|{{escape_uni32}}|[_0-9\p{L}])'
  name_normal: '{{start_char}}{{other_char}}*\b'
  cap_name: '\p{Lu}{{other_char}}*\b'

  wspace_eol: '\s*(?:\n|$)'

  method_param_type_modifier: (?:out|ref|this|params|in)\b

  sql_indicator: |-
    (?x: \s* (?:
    # dml statements
      SELECT | INSERT | REPLACE | DELETE | TRUNCATE | UPDATE | MERGE\s+INTO
    # ddl statements
    | ADD | ALTER | CREATE | DROP
    # conditional
    | IF \s+ (?: NOT \s+ )? EXISTS
    # declaration
    | DECLARE | WITH | BEGIN
    ) \s )

  sql_keywords: |-
    (?x: let | select | equals | from | in | where | join | orderby | group | by
    | on | into | into | ascending | descending )\b(?!\s*[.,;+=&\|\[\]\)])
